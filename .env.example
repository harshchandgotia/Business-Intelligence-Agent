# LLM
GROQ_API_KEY="your-groq-api-key-here"
GROQ_MODEL=llama-3.3-70b-versatile

# Database (use DATABASE_URL or individual fields)
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/bi_agent_db

# Individual DB fields (used if DATABASE_URL is not set)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=bi_agent_db

# Limits
MAX_QUERY_ROWS=1000
MAX_CONVERSATION_TURNS=10
MAX_CRITIQUE_LOOPS=2
CONFIDENCE_THRESHOLD=0.4
